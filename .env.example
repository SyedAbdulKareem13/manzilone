# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nova_crm?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/nova_crm?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# OTP / SMS (mock by default; wire up Twilio/MSG91 in production)
OTP_PROVIDER="mock"
OTP_FROM_EMAIL="no-reply@nova.crm"

# App
NEXT_PUBLIC_APP_NAME="Nova CRM"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

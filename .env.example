# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nova_crm?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/nova_crm?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email (real OTP delivery). Set RESEND_API_KEY to send real emails via Resend
# (https://resend.com -> API Keys). Until set, the OTP is shown in-app (demo).
# OTP_FROM_EMAIL must be a Resend-verified sender, or use onboarding@resend.dev for testing.
RESEND_API_KEY=""
OTP_FROM_EMAIL="Manzil One <onboarding@resend.dev>"

# OTP / SMS (SMS still mock; wire up Twilio/MSG91 for SMS OTP)
OTP_PROVIDER="mock"

# App
NEXT_PUBLIC_APP_NAME="Nova CRM"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
